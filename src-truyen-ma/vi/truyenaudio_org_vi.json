  "mangaDetails": {
    "headers": {
      "Referer": "https://truyenaudio.org"
    },
    "titleSelector": "h1",
    "titleAttribute": "text",
    "thumbnailSelector": "meta[property='og:image']",
    "thumbnailAttribute": "content",
