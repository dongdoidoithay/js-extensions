{
  "id": "9animeto_to_en",
  "name": "web: 9animeto.to",
  "lang": "en",
  "nameLang": "English - Anime",
  "baseUrl": "https://www.9animeto.to",
  "version": "1.0.0",
  "description": "9Anime - Watch HD Anime online with DUB and SUB for FREE",
  "isNsfw": false,
  "supportsLatest": true,
  "cloudflareProtected": true,
  "headers": {
    "Referer": "https://www.9animeto.to/",
    "X-Requested-With": "XMLHttpRequest"
  },
  "tags": [
    { "name": "Action",   "path": "/genre/action/page/{page}/" },
    { "name": "Romance",  "path": "/genre/romance/page/{page}/" },
    { "name": "Comedy",   "path": "/genre/comedy/page/{page}/" },
    { "name": "Fantasy",  "path": "/genre/fantasy/page/{page}/" },
    { "name": "Shounen",  "path": "/genre/shounen/page/{page}/" }
  ],
  "popular": {
    "path": "/animes/?status=&type=&order=update&page={page}",
    "isApi": false,
    "listSelector": ".listupd .bs",
    "titleSelector": ".tt",
    "titleAttribute": "ownText",
    "urlSelector": "a.tip",
    "urlAttribute": "href",
    "thumbnailSelector": ".limit img",
    "thumbnailAttribute": "src",
    "mangaUrlPattern": "{baseUrl}{url}"
  },
  "latest": {
    "path": "/animes/?status=&type=&order=update&page={page}",
    "isApi": false,
    "listSelector": ".listupd .bs",
    "titleSelector": ".tt",
    "titleAttribute": "ownText",
    "urlSelector": "a.tip",
    "urlAttribute": "href",
    "thumbnailSelector": ".limit img",
    "thumbnailAttribute": "src",
    "mangaUrlPattern": "{baseUrl}{url}"
  },
  "search": {
    "path": "/search?search={query}&page={page}",
    "isApi": false,
    "listSelector": ".listupd .bs",
    "titleSelector": ".tt",
    "titleAttribute": "ownText",
    "urlSelector": "a.tip",
    "urlAttribute": "href",
    "thumbnailSelector": ".limit img",
    "thumbnailAttribute": "src",
    "mangaUrlPattern": "{baseUrl}{url}"
  },
  "mangaDetails": {
    "isApi": false,
    "titleSelector": ".bigcontent .infox h1, .infox h1",
    "titleAttribute": "ownText",
    "descriptionSelector": ".bigcontent .infox .desc, .infox .entry-content",
    "descriptionAttribute": "text",
    "thumbnailSelector": ".bigcontent img.attachment-post-thumbnail, .infox img",
    "thumbnailAttribute": "src",
    "genreSelector": ".bigcontent .infox .genxed a, .infox .genxed a",
    "genreAttribute": "text",
    "statusSelector": ".bigcontent .infox .spe span:contains('Status') a, .infox .spe span a",
    "statusAttribute": "text"
  },
  "chapterList": {
    "isApi": false,
    "listSelector": ".eplister ul li",
    "nameSelector": ".epl-title",
    "nameAttribute": "text",
    "urlSelector": "a",
    "urlAttribute": "href",
    "dateSelector": ".epl-date",
    "dateAttribute": "text"
  },
  "pageList": {
    "listSelector": "#nonexistent-force-episode-page-fallback"
  }
}
