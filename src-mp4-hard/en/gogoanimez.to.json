{
  "id": "gogoanimez_to_en",
  "name": "web: gogoanimez.to",
  "lang": "en",
  "nameLang": "English - Anime",
  "baseUrl": "https://gogoanimez.to",
  "version": "1.0.0-beta",
  "description": "GoGoAnimez - Watch anime online in HD",
  "isNsfw": false,
  "supportsLatest": true,
  "cloudflareProtected": true,
  "headers": {
    "Referer": "https://gogoanimez.to/",
    "X-Requested-With": "XMLHttpRequest"
  },
  "tags": [
    { "name": "Action",    "path": "/genre/action?page={page}" },
    { "name": "Romance",   "path": "/genre/romance?page={page}" },
    { "name": "Comedy",    "path": "/genre/comedy?page={page}" },
    { "name": "Fantasy",   "path": "/genre/fantasy?page={page}" },
    { "name": "Shounen",   "path": "/genre/shounen?page={page}" }
  ],
  "popular": {
    "path": "/ajax/page-recent-release?page={page}&type=1",
    "isApi": false,
    "listSelector": "ul.items li",
    "titleSelector": "p.name a",
    "titleAttribute": "text",
    "urlSelector": "p.name a",
    "urlAttribute": "href",
    "thumbnailSelector": "div.img img",
    "thumbnailAttribute": "src",
    "mangaUrlPattern": "{baseUrl}{url}"
  },
  "latest": {
    "path": "/ajax/page-recent-release?page={page}&type=1",
    "isApi": false,
    "listSelector": "ul.items li",
    "titleSelector": "p.name a",
    "titleAttribute": "text",
    "urlSelector": "p.name a",
    "urlAttribute": "href",
    "thumbnailSelector": "div.img img",
    "thumbnailAttribute": "src",
    "mangaUrlPattern": "{baseUrl}{url}"
  },
  "search": {
    "path": "/search.html?keyword={query}&page={page}",
    "isApi": false,
    "listSelector": "ul.items li",
    "titleSelector": "p.name a",
    "titleAttribute": "text",
    "urlSelector": "p.name a",
    "urlAttribute": "href",
    "thumbnailSelector": "div.img img",
    "thumbnailAttribute": "src",
    "mangaUrlPattern": "{baseUrl}{url}"
  },
  "mangaDetails": {
    "isApi": false,
    "titleSelector": ".anime-info h1, h1",
    "titleAttribute": "text",
    "descriptionSelector": ".description, .anime-info .description",
    "descriptionAttribute": "text",
    "thumbnailSelector": ".anime-poster img, .anime-info img",
    "thumbnailAttribute": "src",
    "genreSelector": ".anime-info .genre a, p.type:contains('Genre') a",
    "genreAttribute": "text",
    "statusSelector": ".anime-info .anime-status, p.type:contains('Status') a",
    "statusAttribute": "text"
  },
  "chapterList": {
    "isApi": false,
    "chapterIdSelector": "#episode_page a",
    "chapterIdAttribute": "data-seri",
    "chapterEpEndSelector": "#episode_page a",
    "chapterEpEndAttribute": "data-range-end",
    "chapterCurrentIdScriptRegex": "current_id:\\s*(\\d+)",
    "chapterNonceScriptRegex": "nonce:\\s*'([a-zA-Z0-9]+)'",
    "apiUrlPattern": "{baseUrl}/wp-admin/admin-ajax.php",
    "apiMethod": "POST",
    "apiPostData": "action=load_episode_range&range_start=1&range_end={epEnd}&seri_id={id}&current_id={currentId}&nonce={nonce}",
    "apiResponseType": "json",
    "apiHtmlField": "data",
    "listSelector": "li",
    "nameSelector": ".name"
  },
  "pageList": {
    "listSelector": ".anime_muti_link a.selected",
    "dataHtmlAttribute": "data-video"
  }
}
