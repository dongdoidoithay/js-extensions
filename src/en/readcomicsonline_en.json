{
  "id": "readcomicsonline_en",
  "name": "web: readcomicsonline.ru",
  "lang": "en",
  "nameLang": "English - Comics",
  "baseUrl": "https://readcomicsonline.ru",
  "version": "1.0.1",
  "description": "Read comic DC Marvel online ",
  "isNsfw": false,
  "supportsLatest": true,
  "headers": {
    "Referer": "https://readcomicsonline.ru/"
  },
  "tags": [
    {
      "name": "Comics List",
      "path": "/comic-list?page={page}",
      "headers": {
        "Referer": "https://readcomicsonline.ru/"
      },
      "listSelector": "div.comic-list-layout div.group",
      "titleSelector": "a.line-clamp-2",
      "titleAttribute": "text",
      "urlSelector": "a.line-clamp-2",
      "urlAttribute": "href",
      "thumbnailSelector": "img",
      "thumbnailAttribute": "src"
    },

    {
      "name": "Latest Comic",
      "path": "/latest-release?page={page}",
      "headers": {
        "Referer": "https://readcomicsonline.ru/"
      }
    }
  ],
  "popular": {
    "path": "/latest-release?page={page}",
    "headers": {
      "Referer": "https://readcomicsonline.ru/"
    },
    "listSelector": "div.rounded-xl.border.border-ink-700 > div",
    "titleSelector": "div.min-w-0 > a:first-of-type",
    "titleAttribute": "text",
    "urlSelector": "div.min-w-0 > a:first-of-type",
    "urlAttribute": "href",
    "thumbnailSelector": "img",
    "thumbnailAttribute": "src"
  },
  "search": {
    "path": "/search?query={query}",
    "isApi": true,
    "headers": {
      "Referer": "https://readcomicsonline.ru/"
    },
    "listSelector": "suggestions",
    "titleSelector": "value",
    "urlSelector": "data",
    "thumbnailSelector": "",
    "mangaUrlPattern": "{baseUrl}/comic/{slug}"
  },
  "mangaDetails": {
    "headers": {
      "Referer": "https://readcomicsonline.ru/"
    },
    "titleSelector": "h1",
    "titleAttribute": "text",
    "thumbnailSelector": "img.rounded-xl.object-cover",
    "thumbnailAttribute": "src",
    "statusSelector": "div.mt-4.flex.flex-wrap.gap-2.text-sm > span:first-child",
    "statusAttribute": "text",
    "genreSelector": "dl a[href*='/comic-list/category/']",
    "genreAttribute": "text",
    "descriptionSelector": "div.mt-5.overflow-hidden.rounded-xl.border.border-ink-600 p",
    "descriptionAttribute": "text"
  },
  "chapterList": {
    "headers": {
      "Referer": "https://readcomicsonline.ru/"
    },
    "listSelector": "section.mt-8 div.divide-y > a",
    "urlSelector": "",
    "urlAttribute": "href",
    "nameSelector": "span.font-medium",
    "nameAttribute": "text",
    "dateSelector": "span.text-xs.text-slate-500",
    "dateAttribute": "text"
  },
  "pageList": {
    "headers": {
      "Referer": "https://readcomicsonline.ru/"
    },
    "listSelector": "#reader-all img",
    "urlSelector": "",
    "urlAttribute": "src"
  }
}