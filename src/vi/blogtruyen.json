{
  "id": "blogtruyen_vi",
  "name": "BlogTruyen",
  "lang": "vi",
  "baseUrl": "https://blogtruyen.vn",
  "version": "1.0.2",
  "description": "Cộng đồng truyện tranh lớn nhất Việt Nam.",
  "isNsfw": false,
  "supportsLatest": true,
  "headers": {
    "Referer": "https://blogtruyen.vn/"
  },
  "popular": {
    "path": "/ajax/Category/AjaxLoadMangaByCategory?id=-1&orderBy=3&p={page}",
    "headers": {
      "Referer": "https://blogtruyen.vn/"
    },
    "listSelector": ".list .item",
    "titleSelector": "h3 a",
    "titleAttribute": "text",
    "urlSelector": "h3 a",
    "urlAttribute": "href",
    "thumbnailSelector": ".image img",
    "thumbnailAttribute": "src"
  },
  "latest": {
    "path": "/ajax/Category/AjaxLoadMangaByCategory?id=-1&orderBy=5&p={page}",
    "headers": {
      "Referer": "https://blogtruyen.vn/"
    },
    "listSelector": ".list .item",
    "titleSelector": "h3 a",
    "titleAttribute": "text",
    "urlSelector": "h3 a",
    "urlAttribute": "href",
    "thumbnailSelector": ".image img",
    "thumbnailAttribute": "src"
  },
  "search": {
    "path": "/timkiem?keyword={query}&p={page}",
    "headers": {
      "Referer": "https://blogtruyen.vn/"
    },
    "listSelector": ".list .item",
    "titleSelector": "h3 a",
    "titleAttribute": "text",
    "urlSelector": "h3 a",
    "urlAttribute": "href",
    "thumbnailSelector": ".image img",
    "thumbnailAttribute": "src"
  },
  "mangaDetails": {
    "headers": {
      "Referer": "https://blogtruyen.vn/"
    },
    "titleSelector": ".entry-title",
    "titleAttribute": "text",
    "thumbnailSelector": ".thumbnail img",
    "thumbnailAttribute": "src",
    "authorSelector": ".description p:contains(Tác giả) a",
    "authorAttribute": "text",
    "statusSelector": ".description p:contains(Trạng thái) span",
    "statusAttribute": "text",
    "genreSelector": ".description p:contains(Thể loại) a",
    "genreAttribute": "text",
    "descriptionSelector": ".detail-content",
    "descriptionAttribute": "text"
  },
  "chapterList": {
    "headers": {
      "Referer": "https://blogtruyen.vn/"
    },
    "listSelector": "#list-chapters p",
    "urlSelector": "a",
    "urlAttribute": "href",
    "nameSelector": "a",
    "nameAttribute": "text",
    "dateSelector": ".publishedDate",
    "dateAttribute": "text"
  },
  "pageList": {
    "headers": {
      "Referer": "https://blogtruyen.vn/"
    },
    "listSelector": "article#content img",
    "urlSelector": "",
    "urlAttribute": "src"
  }
}