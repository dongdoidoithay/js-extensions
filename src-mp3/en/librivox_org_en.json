{
  "id": "librivox_org_en",
  "name": "librivox.org",
  "lang": "en",
  "nameLang": "English",
  "baseUrl": "https://librivox.org",
  "version": "1.1.0",
  "description": "Free public domain audiobooks — LibriVox",
  "isNsfw": false,
  "supportsLatest": true,
  "headers": {
    "Referer": "https://librivox.org",
    "X-Requested-With": "XMLHttpRequest"
  },
  "tags": [
    {
      "name": "Recently Added",
      "path": "/search/get_results?primary_key=1&search_category=language&sub_category=&search_page={page}&search_order=catalog_date&project_type=either",
      "headers": {
        "Referer": "https://librivox.org",
        "X-Requested-With": "XMLHttpRequest"
      }
    },
    {
      "name": "Solo Readings",
      "path": "/search/get_results?primary_key=1&search_category=language&sub_category=&search_page={page}&search_order=alpha&project_type=solo",
      "headers": {
        "Referer": "https://librivox.org",
        "X-Requested-With": "XMLHttpRequest"
      }
    }
  ],
  "popular": {
    "path": "/search/get_results?primary_key=1&search_category=language&sub_category=&search_page={page}&search_order=alpha&project_type=either",
    "isApi": true,
    "apiHtmlField": "results",
    "headers": {
      "Referer": "https://librivox.org",
      "X-Requested-With": "XMLHttpRequest"
    },
    "listSelector": "li.catalog-result",
    "titleSelector": "h3 a",
    "titleAttribute": "text",
    "urlSelector": "a.book-cover",
    "urlAttribute": "href",
    "thumbnailSelector": "a.book-cover img",
    "thumbnailAttribute": "src"
  },
  "search": {
    "path": "/search/get_results?primary_key={query}&search_category=title&search_page={page}&search_order=alpha&project_type=either",
    "isApi": true,
    "apiHtmlField": "results",
    "headers": {
      "Referer": "https://librivox.org",
      "X-Requested-With": "XMLHttpRequest"
    },
    "listSelector": "li.catalog-result",
    "titleSelector": "h3 a",
    "titleAttribute": "text",
    "urlSelector": "a.book-cover",
    "urlAttribute": "href",
    "thumbnailSelector": "a.book-cover img",
    "thumbnailAttribute": "src"
  },
  "mangaDetails": {
    "headers": {
      "Referer": "https://librivox.org"
    },
    "titleSelector": "h1.book-title, div.book-page-book-details h1",
    "titleAttribute": "text",
    "thumbnailSelector": "div.book-page-book-art img",
    "thumbnailAttribute": "src",
    "authorSelector": "p.book-author a",
    "authorAttribute": "text",
    "descriptionSelector": "div.description p",
    "descriptionAttribute": "text",
    "genreSelector": "p.book-genre a",
    "genreAttribute": "text"
  },
  "chapterList": {
    "listSelector": "table.chapter-download tbody tr",
    "nameSelector": "td:nth-child(2) a.chapter-name",
    "nameAttribute": "text",
    "urlSelector": "td:nth-child(2) a.chapter-name",
    "urlAttribute": "href"
  }
}
