{
  "id": "nghenhacsong_com_vi",
  "name": "nghenhacsong.com",
  "lang": "vi",
  "nameLang": "Tiếng Việt",
  "baseUrl": "https://nghenhacsong.com",
  "version": "1.1.0",
  "description": "Nhạc Sống Việt Nam - Nhạc sống, nhạc trữ tình, nhạc quê hương",
  "isNsfw": false,
  "supportsLatest": true,
  "headers": {
    "Referer": "https://nghenhacsong.com"
  },
  "tags": [
    {
      "name": "Nhạc Sống Thôn Quê",
      "path": "/browse-nhac-song-mp3-videos-{page}-date.html",
      "headers": { "Referer": "https://nghenhacsong.com" }
    },
    {
      "name": "Nhạc Trữ Tình",
      "path": "/browse-nhac-song-tru-tinh-mp3-videos-{page}-date.html",
      "headers": { "Referer": "https://nghenhacsong.com" }
    },
    {
      "name": "Nhạc Sống Hà Tây",
      "path": "/browse-nhac-song-ha-tay-mp3-videos-{page}-date.html",
      "headers": { "Referer": "https://nghenhacsong.com" }
    },
    {
      "name": "Nhạc Sống Tây Bắc",
      "path": "/browse-nhac-song-tay-bac-mp3-videos-{page}-date.html",
      "headers": { "Referer": "https://nghenhacsong.com" }
    },
    {
      "name": "Nhạc Sống Remix",
      "path": "/browse-nhac-song-remix-mp3-videos-{page}-date.html",
      "headers": { "Referer": "https://nghenhacsong.com" }
    }
  ],
  "popular": {
    "path": "/newvideos.html?&page={page}",
    "headers": { "Referer": "https://nghenhacsong.com/" },
    "listSelector": "li.fn-song",
    "titleSelector": "p.nameheader",
    "titleAttribute": "text",
    "urlSelector": "a.ellipsis",
    "urlAttribute": "href",
    "thumbnailSelector": "img.imgicon3",
    "thumbnailAttribute": "src"
  },
  "search": {
    "path": "/page/{page}?s={query}",
    "headers": { "Referer": "https://nghenhacsong.com/" },
    "listSelector": "li.fn-song",
    "titleSelector": "p.nameheader",
    "titleAttribute": "text",
    "urlSelector": "a.ellipsis",
    "urlAttribute": "href",
    "thumbnailSelector": "img.imgicon3",
    "thumbnailAttribute": "src"
  },
  "mangaDetails": {
    "headers": { "Referer": "https://nghenhacsong.com" },
    "titleSelector": "h1",
    "titleAttribute": "text",
    "thumbnailSelector": "img.imgicon3",
    "thumbnailAttribute": "src",
    "descriptionSelector": "p.catname",
    "descriptionAttribute": "text"
  },
  "chapterList": {
    "scriptSelector": "script",
    "scriptItemRegex": "m4a\\s*:\\s*[\"'](https?://[^\"'\\s]+)[\"']",
    "scriptNameGroup": 1,
    "scriptUrlGroup": 1
  },
  "pageList": {
    "listSelector": "source[src*='.mp3'], audio source",
    "urlSelector": "self",
    "urlAttribute": "src"
  }
}
